              "raw": "{\n  \"bio\": \"Experienced home cleaning professional.\",\n  \"skills\": \"deep-cleaning,kitchen,bathroom\",\n  \"service_area\": \"Downtown\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create/replace own provider profile (upsert). Role: PROVIDER (own); ADMIN (any via body user_id). is_verified ignored unless ADMIN."
          },
          "response": []
        }
      ]
    },
