    {
      "name": "Bookings",
      "description": "Bookings and state-transition actions (/bookings).",
      "item": [
        {
          "name": "POST /bookings",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/bookings",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"service_id\": 1,\n  \"scheduled_at\": \"2026-06-25T10:00:00.000Z\",\n  \"address\": \"12 Maple St\",\n  \"notes\": \"Please bring eco supplies\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Create a booking (starts PENDING; price snapshotted). Role: CUSTOMER (self) or ADMIN (may set customer_id/provider_id)."
          },
          "response": []
        },
        {
          "name": "GET /bookings",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/bookings?page=1&page_size=20&sort_by=scheduled_at&sort_order=desc&status=PENDING&service_id=1&customer_id=4&provider_id=2&scope=assigned&scheduled_from=2026-06-01T00:00:00.000Z&scheduled_to=2026-06-30T00:00:00.000Z&include=service,customer,provider,payment",
              "host": ["{{baseUrl}}"],
              "path": ["bookings"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "page_size", "value": "20" },
                { "key": "sort_by", "value": "scheduled_at", "description": "allow-list: id, scheduled_at, status, created_at" },
                { "key": "sort_order", "value": "desc" },
                { "key": "status", "value": "PENDING", "description": "BookingStatus filter", "disabled": true },
                { "key": "service_id", "value": "1", "disabled": true },
                { "key": "customer_id", "value": "4", "description": "ADMIN only", "disabled": true },
                { "key": "provider_id", "value": "2", "description": "ADMIN only", "disabled": true },
                { "key": "scope", "value": "assigned", "description": "PROVIDER only: assigned|available|all", "disabled": true },
                { "key": "scheduled_from", "value": "2026-06-01T00:00:00.000Z", "disabled": true },
                { "key": "scheduled_to", "value": "2026-06-30T00:00:00.000Z", "disabled": true },
                { "key": "include", "value": "service,customer,provider,payment", "disabled": true }
              ]
            },
            "description": "List bookings, scoped by role. CUSTOMER (own), PROVIDER (own + available), ADMIN (all)."
          },
          "response": []
        },
        {
          "name": "GET /bookings/:id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
