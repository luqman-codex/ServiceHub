{
  "info": {
    "_postman_id": "b3f1c2d4-5e6a-47b8-9c0d-1e2f3a4b5c6d",
    "name": "ServiceHub REST API",
    "description": "Postman collection for the ServiceHub On-Demand Service API (v1). Base path /api/v1. Auth is JWT Bearer; run 'POST /auth/login' first (seeded ADMIN by default) to populate the {{token}} collection variable automatically via its test script. All 53 endpoints from 02-API-CONTRACT.md §11 are included.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "event": [],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000/api/v1",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Authentication & token management (/auth).",
      "item": [
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Casey Customer\",\n  \"email\": \"casey@example.com\",\n  \"password\": \"Passw0rd123\",\n  \"phone\": \"+10000000099\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Self-service signup. Always creates a CUSTOMER. Role: Public (no token)."
          },
          "response": []
        },
        {
          "name": "POST /auth/login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Store the access token from the login response into the collection variable",
                  "// so subsequent authenticated requests use it via Bearer {{token}}.",
                  "pm.test('login succeeded', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "pm.collectionVariables.set('token', pm.response.json().data.access_token);",
                  "console.log('token set from data.access_token');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "auth": { "type": "noauth" },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@servicehub.test\",\n  \"password\": \"Admin@12345\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Authenticate and receive an access token. Role: Public. Test script stores data.access_token into the collection {{token}} variable so subsequent requests authenticate automatically. Default body uses the seeded ADMIN account."
          },
          "response": []
        },
        {
          "name": "POST /auth/logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "logout"]
            },
            "description": "Client-side logout acknowledgement. Role: any authenticated. Body: none."
          },
          "response": []
        },
        {
          "name": "POST /auth/refresh",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/refresh",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "refresh"]
            },
            "description": "(Reserved) Refresh access token. Role: any authenticated. MVP returns 501 NOT_IMPLEMENTED."
          },
          "response": []
        },
        {
          "name": "GET /auth/me",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "me"]
            },
            "description": "Current authenticated principal (UserDTO). Role: any authenticated."
          },
          "response": []
        }
      ]
    },
