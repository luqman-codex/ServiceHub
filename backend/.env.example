# ── Runtime ──────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ── MySQL ────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=servicehub
DB_USER=servicehub
DB_PASSWORD=change-me

# ── Auth / JWT ───────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string-min-16-chars
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# ── CORS (comma-separated origins: admin web, user site, provider portal, expo dev) ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081

# ── Auth rate limiting (02 §10) ──────────────────────────
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=dev
